{
  "name": "bookapp-mobile",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web --port 5000 --host lan",
    "dev:device": "expo start --dev-client --tunnel",
    "dev:device:lan": "expo start --dev-client --host lan",
    "build:android:dev": "eas build --profile development --platform android",
    "build:android:preview": "eas build --profile preview --platform android",
    "build:ios:beta": "eas build --profile beta --platform ios",
    "submit:ios:beta": "eas submit --profile beta --platform ios --latest",
    "update:dev": "eas update --branch development",
    "update:preview": "eas update --branch preview",
    "check:series-covers": "npx tsx scripts/check_series_covers.ts"
  },
  "dependencies": {
    "@expo/metro-runtime": "~55.0.6",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@supabase/supabase-js": "^2.99.0",
    "expo": "~55.0.5",
    "expo-apple-authentication": "^55.0.11",
    "expo-auth-session": "^55.0.12",
    "expo-camera": "~55.0.11",
    "expo-clipboard": "~55.0.11",
    "expo-constants": "~55.0.2",
    "expo-dev-client": "~55.0.22",
    "expo-document-picker": "~55.0.11",
    "expo-file-system": "~55.0.14",
    "expo-haptics": "~55.0.9",
    "expo-linear-gradient": "^55.0.13",
    "expo-linking": "~55.0.7",
    "expo-router": "~55.0.4",
    "expo-sharing": "~55.0.18",
    "expo-status-bar": "~55.0.4",
    "expo-updates": "~55.0.18",
    "expo-web-browser": "^55.0.12",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-view-shot": "4.0.3",
    "react-native-web": "~0.21.2",
    "react-native-webview": "13.16.0"
  },
  "devDependencies": {
    "@types/react": "~19.2.0",
    "babel-preset-expo": "~55.0.8",
    "openai": "^6.34.0",
    "typescript": "~5.8.3"
  }
}

{
  "expo": {
    "name": "readstack",
    "slug": "bookapp-mobile",
    "scheme": "bookappmobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "plugins": [
      "expo-router",
      "expo-apple-authentication",
      "expo-dev-client"
    ],
    "ios": {
      "bundleIdentifier": "com.readstack.app",
      "usesAppleSignIn": true
    },
    "android": {
      "package": "com.readstack.app"
    },
    "experiments": {
      "typedRoutes": true
    },
    "web": {
      "output": "single"
    }
  }
}

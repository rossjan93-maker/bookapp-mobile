{
  "expo": {
    "name": "bookapp-mobile",
    "slug": "bookapp-mobile",
    "scheme": "bookappmobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "plugins": [
      "expo-router",
      "expo-apple-authentication"
    ],
    "ios": {
      "usesAppleSignIn": true
    },
    "experiments": {
      "typedRoutes": true
    },
    "web": {
      "output": "single"
    }
  }
}
